    <file path="public/contact.html" role="Contact 페이지" />
    <file path="public/login.html" role="로그인 페이지" />
    <file path="public/dashboard-admin.html" role="관리자 대시보드" />
    <file path="public/blog-editor.html" role="블로그 에디터" />
  </locked-files>

  <!-- ═══════════════════════════════════════════════════════ -->
  <!-- 공통 헤더/풋터 컴포넌트 — 절대 수정/삭제/재해석/재배포 금지 -->
  <!-- ═══════════════════════════════════════════════════════ -->
  <!--
    ⛔ 공통 헤더/풋터 시스템 ⛔
    - 모든 일반 페이지(7개)는 공통 헤더/풋터로 분리 관리됨
    - 페이지 HTML에 <div id="header-one"></div>, <div id="footer-one"></div> 플레이스홀더만 존재
    - src/worker.js의 HTMLRewriter가 HEADER_HTML, FOOTER_HTML로 교체 주입
    - public/components/header.html, footer.html은 동기화용 원본

    ██ 적용 페이지 ██
    index.html, about.html, services.html, product.html,
    solution.html, blog.html, contact.html

    ██ 절대 금지 ██
    1. 수정 금지 — 관리자의 명시적 파일명 지정 지시 없이 수정 불가
    2. 분리 금지 — 공통 컴포넌트를 개별 페이지에 하드코딩 금지
    3. 재해석 금지 — "개선", "최적화", "리팩토링" 명목의 구조 변경 금지
    4. 재배포 금지 — 컴포넌트 내용을 다른 파일로 복사/이동/재구성 금지
    5. 플레이스홀더 제거 금지 — 페이지 내 #header-one, #footer-one div 삭제 금지
  -->
  <locked-files category="COMMON_HEADER_FOOTER" status="ABSOLUTE_LOCK">
    <file path="public/components/header.html" role="공통 헤더 원본" lock="수정/삭제/분리/재해석/재배포 절대 금지" />
    <file path="public/components/footer.html" role="공통 풋터 원본" lock="수정/삭제/분리/재해석/재배포 절대 금지" />
    <file path="src/worker.js" role="HEADER_HTML/FOOTER_HTML 주입 (HTMLRewriter)" lock="헤더/풋터 템플릿 수정 절대 금지. API 라우트 추가만 허용" />
  </locked-files>

