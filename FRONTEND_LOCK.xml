<?xml version="1.0" encoding="UTF-8"?>
<!--
  ⛔⛔⛔ N0004 프론트엔드 디자인/UI 절대 잠금 ⛔⛔⛔
  생성일: 2026-03-09

  아래 목록의 모든 파일은 완성된 디자인/UI 파일입니다.
  어떤 AI 에이전트, 어떤 채팅 세션에서도 아래 규칙을 위반할 수 없습니다.

  ██ 절대 금지 사항 ██
  1. 수정 금지 — 한 글자, 한 줄도 변경 불가
  2. 삭제 금지 — 파일 삭제, 내용 삭제, 부분 삭제 모두 금지
  3. 재해석 금지 — "개선", "최적화", "리팩토링" 명목의 변경 금지
  4. 재배포 금지 — 이 파일들의 내용을 다른 파일로 복사/이동/재구성 금지
  5. 덮어쓰기 금지 — 어떤 이유로든 기존 내용을 새 내용으로 교체 금지

  ██ 유일한 예외 ██
  관리자가 명시적으로 "이 파일 수정해" 라고 파일명을 지정한 경우에만 해당 파일만 수정 가능.
  그 외 모든 경우 절대 불가.
-->
<frontend-lock version="1.0" created="2026-03-09" status="ABSOLUTE_LOCK">

  <!-- ═══════════════════════════════════════ -->
  <!-- HTML 페이지 — 절대 수정/삭제/재해석 금지 -->
  <!-- ═══════════════════════════════════════ -->
  <locked-files category="HTML_PAGES">
    <file path="public/index.html" role="홈페이지" />
    <file path="public/about.html" role="About Us 페이지" />
    <file path="public/services.html" role="Service 페이지" />
    <file path="public/product.html" role="Product 페이지" />
    <file path="public/solution.html" role="Solution 페이지" />
